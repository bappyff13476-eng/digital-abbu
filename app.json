{
  "expo": {
    "name": "DIGITAL ABBU",
    "slug": "digital-abbu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "digitalabbu",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#090D1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.disciplinev8.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#090D1A"
      },
      "package": "com.disciplinev8.app",
      "permissions": [
        "SYSTEM_ALERT_WINDOW",
        "RECEIVE_BOOT_COMPLETED",
        "FOREGROUND_SERVICE",
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "digital-abbu-local"
      }
    }
  }
}
